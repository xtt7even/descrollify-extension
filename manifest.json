{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "1.2.0",
  "description": "__MSG_extDesc__",
  "default_locale": "en",
  "icons": {
    "48": "icon48.png",
    "96": "icon96.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "/images/logo_transparent_white.png",
        "/lines.json",
        "_locales/*/messages.json",
        "popup.js",
        "options.js",
        "fonts/static/RobotoCondensed-Regular.ttf",
        "fonts/static/RobotoCondensed-Bold.ttf"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icon48.png",
      "96": "icon96.png"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.youtube.com/*"],
      "js": ["i18n.js", "content.js"],
      "css": ["blocker.css"]
    }
  ],
  "permissions": ["tabs", "storage", "activeTab", "alarms"],
  "options_page": "options.html"
}
